# Supabase Configuration
# Use the Transaction Pooler URL (port 6543) for DATABASE_URL at runtime
# Use the Direct Connection URL (port 5432) when running db:push migrations
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Application Configuration
APP_PORT=5000

# OpenAI API Configuration
OPENAI_API_KEY=your_actual_openai_api_key_here

# Session Secret (generate a random string)
SESSION_SECRET=your_actual_session_secret_here

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth (https://developers.facebook.com/apps)
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# App URL (used for OAuth callback URLs)
APP_URL=http://localhost:5000
